{
  "name": "api",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:migrate": "npm run knex migrate:latest",
    "db:migrate:down": "npm run knex migrate:down",
    "db:migrate:make:schema": "npm run knex -- migrate:make --stub ./src/_db/migration.schema.stub",
    "db:migrate:make:data": "npm run knex -- migrate:make --stub ./src/_db/migration.data.stub",
    "db:rollback": "npm run knex migrate:rollback",
    "db:seed": "npm run knex seed:run",
    "db:setup": "tsx ./src/_db/setup.ts && npm run db:migrate && npm run db:seed",
    "knex": "npx tsx ./node_modules/.bin/knex --knexfile src/_db/knexfile.ts",
    "lint:all": "biome lint --diagnostic-level=error .",
    "lint:fix": "biome lint --diagnostic-level=error --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "start": "TZ=UTC tsx src/index.ts",
    "start:dev": "TZ=UTC npx nodemon --config ./nodemon.json",
    "test:unit": "jest --group=-integration"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "jest": "^30.2.0",
    "jest-extended": "^7.0.0",
    "jest-runner-groups": "^2.2.0",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hapi/hapi": "^21.4.4",
    "@hapi/inert": "^7.1.0",
    "@hapi/jwt": "^3.2.3",
    "@hapi/vision": "^7.0.3",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.2.3",
    "hapi-swagger": "^17.3.2",
    "joi": "^17.13.3",
    "knex": "^3.1.0",
    "nodemailer": "^8.0.1",
    "objection": "^3.1.5",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.3"
  },
  "jest": {
    "preset": "ts-jest",
    "runner": "groups",
    "globalSetup": "./jestSetupGlobal.js",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "knexfile.test.ts"
    ],
    "setupFilesAfterEnv": [
      "./jestSetupTestSuite.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest"
      ]
    }
  }
}
