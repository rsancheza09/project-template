import { Knex } from 'knex';

export const up = async (knex: Knex): Promise<void> => {
  if (!['staging', 'production', 'demo'].includes(process.env.ENV || ''))
    return;
};

export const down = async (knex: Knex): Promise<void> => {
  if (!['staging', 'production', 'demo'].includes(process.env.ENV || ''))
    return;
};
