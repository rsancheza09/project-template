{
  "compilerOptions": {
    "lib": ["es2023"],
    "target": "es2019",
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": "src",
    "paths": {
      "@components/*": ["shared/components/*"],
      "@shared/*": ["shared/*"],
      "@utils/*": ["shared/utils/*"]
    },
    "allowJs": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["*.ts", "*.tsx", "src/**/*"]
}
